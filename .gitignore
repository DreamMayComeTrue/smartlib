# ─────────────────────────────────────────────────────────────
# SmartLib — Root .gitignore
# Belt-and-braces: subdirectories have their own .gitignore too;
# this catches anything missed there.
# ─────────────────────────────────────────────────────────────

# ───── Secrets — NEVER commit these ─────
# (Pattern with no slash applies anywhere in the tree)
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json

# ───── PHP / Composer ─────
vendor/
composer.phar
*.lock.bak

# ───── Node / Vite (frontend) ─────
node_modules/
dist/
.vite/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───── Build artifacts ─────
build/
out/
.cache/

# ───── OS junk ─────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ───── Editor / IDE folders ─────
.vscode/
.idea/
*.suo
*.user
*.sln.docstates
*.sublime-workspace

# ───── Logs / temp ─────
*.log
*.tmp
*.swp
*~

# ───── Generated reports / outputs we don't track ─────
docs/Technical_Report.docx     # generated from the markdown skeleton
docs/Technical_Report.pdf
