# SmartLib Backend — Environment variables
# Copy this file to `.env` (same folder) and fill in real values.
# NEVER commit the real .env file to git.

# Database
# Use 127.0.0.1 (not localhost) to force a TCP connection. With "localhost"
# MySQL on Windows may try a named-pipe socket which can fail under MySQL 8.x.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=smartlib
DB_USER=root
DB_PASS=

# JWT
# Generate a strong random secret. On Linux/macOS:
#   openssl rand -base64 48
# On Windows PowerShell:
#   [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGO=HS256
JWT_TTL=3600          # token lifetime in seconds (1 hour)

# CORS — allowed frontend origin (Vite dev server default)
CORS_ORIGIN=http://localhost:5173

# Borrow rules
BORROW_DAYS=14        # how many days until a borrow becomes overdue
